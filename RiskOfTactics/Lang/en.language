    "HANDOFJUSTICE": "Hand Of Justice",
    "ITEM_HANDOFJUSTICE_NAME": "Hand Of Justice",
    "ITEM_HANDOFJUSTICE_PICKUP": "Gain bonus damage and omnivamp scaling with your current HP.",
    "ITEM_HANDOFJUSTICE_DESC": "Gain <style=cIsDamage>{Crit Chance}% crit chance</style>. This item grants 2 effects:\n\t<style=cIsDamage>+{Bonus Damage Percent}% <style=cStack>(+{Bonus Damage Percent Per Stack}% per stack)</style> BASE damage</style>\n\t<style=cIsHealing>+{Omnivamp}% <style=cStack>(+{Omnivamp Per Stack}% per stack)</style> omnivamp</style>\nWhile at or above <style=cIsHealth>50% max HP</style>, double the first effect. While below <style=cIsHealth>50% max HP</style>, double the second.",
    "ITEM_HANDOFJUSTICE_LORE": "",

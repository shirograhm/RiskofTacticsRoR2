    "ITEM_ARCHANGELSSTAFF_NAME": "Archangel's Staff",
    "ITEM_ARCHANGELSSTAFF_PICKUP": "During the teleporter event, periodically gain <style=cIsDamage>BASE damage</style>.",
    "ITEM_ARCHANGELSSTAFF_DESC": "During the teleporter event, gain a stack of <style=cWorldEvent>Foresight</style> every <style=cIsUtility>{Tick Duration} seconds</style>. Each stack grants <style=cIsDamage>{Flat Damage Per Tick} <style=cStack>(+{Flat Damage Per Tick} per stack)</style> BASE damage</style>. Stacks reset at the start of each stage.",

    "ITEM_CROWNGUARD_DESC": "Upon activation of the teleporter, gain a <style=cIsUtility>{Effect Shield}% <style=cStack>(+{Effect Shield Extra Stacks}% per stack)</style> max HP shield</style> for <style=cIsUtility>{Effect Duration} seconds</style>. When the shield expires, gain <style=cIsDamage>{Effect Damage} <style=cStack>(+{Effect Damage Extra Stacks}% per stack)</style> BASE damage</style>.",
    "ITEM_CROWNGUARD_LORE": "",
